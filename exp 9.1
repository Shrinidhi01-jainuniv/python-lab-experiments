import numpy as np
import pandas as pd
a=np.array([1,2,3])
b=np.array([4,5,6])
print("array A:", a)
print("array B:", b)
print(" Addition:", a+b)
print(" multiplication:", a*b)

S=pd.Series([100,200,300])
print("\n pandas series")
print(S)

df=pd.DataFrame
df=pd.DataFrame({
    "Product": ["Pen", "Book" , "Bag"],
    "Price": [10,50,500] })
print("\n pandas DataFrame:")
print(df)


