# PANDAS AND MATPLOTLIB
import pandas as pd
import matplotlib.pyplot as plt

df = pd.DataFrame ({
    'NAME':['KRITI' , 'AKRITI' , 'DIKSHA' , 'THRISHA' , 'YASHVI'],
    'USN':[ 512 , 234 , 234, 516, 501],
    'SPECALIZATION':['mact' , 'ctis' , 'da' , 'gen a' , 'gen b'],
    'SUBJECT': [ 'Python' , 'ct' , 'P&S' , 'ada' , 'ada' ],
    'MARKS':[ 23 , 19 , 24 , 25 , 22]
    })
print(df)

# PLOT CHART
plt.bar(df["NAME"],df["MARKS"])
plt.xlabel("NAME")
plt.ylabel("MARKS")
plt.title("RESULTS")

